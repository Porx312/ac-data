PORT=3000

# Carpeta base de instalación de Assetto Corsa (donde están las carpetas de servidores)
SERVERS_PATH=C:\Program Files (x86)\Steam\steamapps\common\assettocorsa

# Supabase / Postgres — URI del pooler (puerto 6543) o la que use tu app
DATABASE_URL=postgresql://postgres.PROJECT_REF:TU_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

# drizzle-kit migrate / introspection: conexión directa (puerto 5432). Opcional.
DIRECT_URL=postgresql://postgres:TU_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Debe coincidir con instance_id en la tabla ac_server_control (alias: VPS_ID)
AC_INSTANCE_ID=default

# Protección de la API HTTP
API_KEY=cambia_esto_por_un_secreto_largo

# Firma de webhooks de batallas (debe coincidir con quien envía los webhooks)
BATTLE_WEBHOOK_SECRET=

# Poller de control de servidores (ms)
SERVER_CONTROL_POLL_MS=5000

# Rotación diaria: intervalo entre reinicios cuando daily_restart_enabled=true (ms). Por defecto 24 h en código.
# DAILY_RESTART_INTERVAL_MS=86400000
