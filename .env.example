PORT=3000

# Base path that contains each AC server folder (cfg/server_cfg.ini lives below)
SERVERS_PATH=C:\Program Files (x86)\Steam\steamapps\common\assettocorsa

# HTTP API key used by the panel to talk to this bridge
API_KEY=cambia_esto_por_un_secreto_largo

# Identifies this VPS in Convex / Redis routing
AC_INSTANCE_ID=vps-eu-1

# ── Redis (single source of truth for events and config) ──
REDIS_HOST=
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SSL=false
REDIS_STREAM_KEY=ac:events
REDIS_CONFIG_STREAM_KEY=ac:config
# Group is shared across the entire fleet so Redis load-balances events.
# Consumer name MUST be unique per VPS (defaults to ac-data-${AC_INSTANCE_ID}
# when left unset, which is what you want).
REDIS_CONSUMER_GROUP=ac-data-consumers
# REDIS_CONSUMER_NAME=

# ── Convex (direct admin API) ──
CONVEX_DEPLOYMENT_URL=https://your-deployment.convex.cloud
CONVEX_PRODUCT_KEY=prod:your-deployment|your-token
CONVEX_INGEST_SECRET=tu_ingest_secret
CONVEX_WORKER_SECRET=tu_worker_secret
CONVEX_CONFIG_VERSION_QUERY=timeAttackServers:getWorkerInstanceConfigVersion
CONVEX_CONFIG_SNAPSHOT_QUERY=timeAttackServers:getWorkerInstanceServerConfigs
CONVEX_MUTATION_BATCH=serverEvents:ingestWorkerEventsBatch

# ── Per-VPS role toggles ──
# REDIS_EVENTS_BRIDGE_ENABLED:
#   Recommended: true on EVERY VPS. They share REDIS_CONSUMER_GROUP so Redis
#   load-balances events across them (each event processed exactly once, no
#   single point of failure). Set to false only if you want a single-primary
#   topology where one node forwards all events.
# REDIS_CONFIG_SYNC_ENABLED:
#   Recommended: true on ONLY one VPS. The publisher polls Convex and writes
#   snapshots to ac:config. Multiple publishers would just duplicate work.
REDIS_EVENTS_BRIDGE_ENABLED=true
REDIS_CONFIG_SYNC_ENABLED=true
REDIS_CONFIG_SYNC_INTERVAL_MS=5000

# ── Local server lifecycle reconciler ──
# Each VPS should keep this enabled: it consumes ac:config and applies INI
# changes + start/stop/restart for the servers tied to its AC_INSTANCE_ID.
REDIS_CONFIG_APPLIER_ENABLED=true
# Leave these unset to auto-derive per-VPS values from AC_INSTANCE_ID
# (group=ac-data-config-appliers-<instanceId>, consumer=applier-<instanceId>).
# Each VPS MUST have its own consumer group so every node sees every snapshot.
# REDIS_CONFIG_APPLIER_GROUP=
# REDIS_CONFIG_APPLIER_NAME=
